{
  "name": "@eddalabs/counter-cli",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "test-undeployed": "npm --workspace @eddalabs/counter-contract run test",
    "prepare-tui": "npm --workspace @eddalabs/counter-contract run build && npm run build",
    "tui-undeployed": "npm run prepare-tui && node dist/tui_standalone.js",
    "tui-preview": "npm run prepare-tui && node dist/tui_preview.js",
    "tui-preprod": "npm run prepare-tui && node dist/tui_preprod.js",
    "setup-undeployed": "docker compose -f standalone.yml up -d && for attempt in $(seq 1 60); do if curl -fsS http://127.0.0.1:6300/version >/dev/null; then exit 0; fi; sleep 5; done; echo 'Proof server did not become ready within 5 minutes.' >&2; exit 1",
    "ps-undeployed": "docker compose -f ps-undeployed.yml up",
    "ps-preview": "docker compose -f ps-preview.yml up",               
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "indexer-client-testing": "vitest run src/test/indexer-client.test.ts"
  },
  "dependencies": {    
    "@eddalabs/counter-contract": "*"    
  }
}
